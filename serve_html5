#!/usr/bin/env python3
"""Serve latest html5 build with aggressive no-cache headers."""
import http.server, os, socketserver, sys, glob

BUILDS = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                     "dragonruby-macos", "builds")
dirs = sorted(glob.glob(os.path.join(BUILDS, "beat2r-html5-*")))
if not dirs:
    print("no beat2r-html5-* build found", file=sys.stderr); sys.exit(1)
target = dirs[-1]
os.chdir(target)
print(f"serving {target} at http://localhost:8000")

class H(http.server.SimpleHTTPRequestHandler):
    def end_headers(self):
        self.send_header("Cache-Control", "no-store, no-cache, must-revalidate, max-age=0")
        self.send_header("Pragma", "no-cache")
        self.send_header("Expires", "0")
        super().end_headers()

socketserver.TCPServer.allow_reuse_address = True
with socketserver.TCPServer(("", 8000), H) as httpd:
    httpd.serve_forever()
